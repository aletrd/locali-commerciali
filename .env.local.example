# ============================================================
# LocaliCommerciali.it — Variabili d'ambiente
# Copia questo file in .env.local e compila i valori reali
# MAI committare .env.local su Git!
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (da Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://tuoprogetto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe (da dashboard.stripe.com)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# ID prezzi mensili (da Stripe → Products)
STRIPE_PRICE_BASE=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENZIA=price_...

# PayPal (da developer.paypal.com)
PAYPAL_CLIENT_ID=AX...
PAYPAL_SECRET=EH...
PAYPAL_ENV=sandbox   # cambia in 'live' per produzione

# Resend (da resend.com — email automatiche)
RESEND_API_KEY=re_...

# Email admin (per notifiche bonifici ecc.)
EMAIL_ADMIN=info@localicommerciali.it

# Dati bonifico bancario (visibili agli utenti)
NEXT_PUBLIC_IBAN=IT60 X054 2811 1010 0000 0123 456
NEXT_PUBLIC_BIC=BLOPIT22
NEXT_PUBLIC_BANCA=Banco BPM
